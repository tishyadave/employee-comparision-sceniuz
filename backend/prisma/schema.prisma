generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  ADMIN
}

enum AnswerOption {
  A
  B
  C
  D
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  department    String?
  role          Role      @default(EMPLOYEE)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  selfAssessment SelfAssessment?
  testAttempts   TestAttempt[]

  @@map("users")
}

model SelfAssessment {
  id                String   @id @default(cuid())
  userId            String   @unique
  overallPercentage Float
  createdAt         DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id])
  ratings SubtopicRating[]
}

model SubtopicRating {
  id               String @id @default(cuid())
  selfAssessmentId String
  topicId          String  // e.g. "dax_basic"
  subtopicId       String  // e.g. "dax_aggregation"
  rating           Int     // 1–5

  selfAssessment SelfAssessment @relation(fields: [selfAssessmentId], references: [id])

  @@unique([selfAssessmentId, subtopicId])
}

model Question {
  id           String       @id @default(uuid())
  questionText String       @map("question_text")
  optionA      String       @map("option_a")
  optionB      String       @map("option_b")
  optionC      String       @map("option_c")
  optionD      String       @map("option_d")
  correctAnswer AnswerOption @map("correct_answer")
  topic        String
  createdAt    DateTime     @default(now()) @map("created_at")

  responses Response[]

  @@map("questions")
}

model TestAttempt {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  startedAt       DateTime      @default(now()) @map("started_at")
  submittedAt     DateTime?     @map("submitted_at")
  timeTakenSeconds Int?         @map("time_taken_seconds")
  scorePercentage Float?        @map("score_percentage")
  totalQuestions  Int           @map("total_questions")
  correctAnswers  Int?          @map("correct_answers")
  status          AttemptStatus @default(IN_PROGRESS)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses Response[]

  @@map("test_attempts")
}

model Response {
  id             String       @id @default(uuid())
  attemptId      String       @map("attempt_id")
  questionId     String       @map("question_id")
  selectedAnswer AnswerOption? @map("selected_answer")
  isCorrect      Boolean?     @map("is_correct")
  answeredAt     DateTime     @default(now()) @map("answered_at")

  attempt  TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("responses")
}
